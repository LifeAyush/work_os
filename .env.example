# Supabase — Project Settings → API (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose to the client or commit real values
SUPABASE_SERVICE_ROLE_KEY=

# Optional — shown in “Welcome back, …” when not signed in / as fallback
NEXT_PUBLIC_DISPLAY_NAME=

# Optional — comma-separated Google account emails allowed to use the API (omit to allow any signed-in user)
ALLOWED_GOOGLE_EMAIL=
